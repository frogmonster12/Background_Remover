    "eslint": "^9.26.0",
    "happy-dom": "^20.9.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.60.1",
    "vite": "^6.3.5",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.5.2"
  }
